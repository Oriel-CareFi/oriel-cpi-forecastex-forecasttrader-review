# Paste into Streamlit Cloud → App settings → Secrets (must be valid TOML).
# String values need quotes. Numbers can be bare integers.

KALSHI_ENABLE_LIVE_CPI = "true"
KALSHI_CPI_SERIES_TICKER = "KXCPI"
KALSHI_API_BASE_URL = "https://api.elections.kalshi.com/trade-api/v2"
KALSHI_API_BASE_URL_FALLBACK = "https://trading-api.kalshi.com/trade-api/v2"
KALSHI_TRY_FALLBACK_HOST = "true"
KALSHI_PRICE_MODE = "mid"
KALSHI_CACHE_SECONDS = 60
KALSHI_MIN_OPEN_INTEREST = 25
KALSHI_MIN_VOLUME = 10
KALSHI_MAX_WIDE_SPREAD = "0.20"
KALSHI_MIN_CONTRACTS_PER_MATURITY = 2
KALSHI_MAX_MATURITIES = 6
KALSHI_TIMEOUT_SECONDS = "20"
KALSHI_MAX_RETRIES = 6
KALSHI_BACKOFF_SECONDS = "0.9"
KALSHI_HTTP_CLOSE_CONNECTION = "true"
